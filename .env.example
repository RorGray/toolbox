# Copy to `.env` for local development: `cp .env.example .env`, then `npm run dev`.
# Loaded by node --env-file. For running Toolbox WITHOUT an Authentik proxy.

# No proxy locally, so don't reject requests that lack the Authentik header.
REQUIRE_AUTH_HEADER=false

# Any authenticated user may edit (empty = no group requirement).
ADMIN_GROUP=

# Fallback identity used when no Authentik header is present, so the browser can
# add/edit entries. DEV_GROUPS only matters if ADMIN_GROUP above is non-empty.
DEV_USER=dev
DEV_GROUPS=toolbox-admins

# Local paths (the /data defaults only exist inside the container).
DATA_FILE=./data/tools.json
ICON_DIR=./icons
